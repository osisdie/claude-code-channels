# Channel plugins (bidirectional DM bridge via --channels)

## ─── Telegram ────────────────────────────────────
TELEGRAM_BOT_TOKEN=

## ─── Discord ─────────────────────────────────────
DISCORD_BOT_TOKEN=

# Broker channels (standalone message broker, not --channels)

## ─── Slack (broker: polling DMs, invokes claude -p) ───
## Slack Bot Token (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=

## ─── LINE (broker: webhook server, invokes claude -p) ───
## LINE Developers Console (from https://developers.line.biz/console/)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

## ─── LINE Relay (cloud webhook + local bridge) ───
## Use with: ./start.sh line-relay
LINE_RELAY_URL=
LINE_RELAY_SECRET=

## ─── WhatsApp (broker: relay bridge, invokes claude -p) ───
## Meta Cloud API (from https://developers.facebook.com/apps/)
## Use with: ./start.sh whatsapp
WA_RELAY_URL=
WA_RELAY_SECRET=
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_VERIFY_TOKEN=

## ─── Microsoft Teams (broker: relay bridge, invokes claude -p) ───
## Azure Bot Service (from https://portal.azure.com/)
## Use with: ./start.sh teams
TEAMS_RELAY_URL=
TEAMS_RELAY_SECRET=
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=


# Commands: /yt2pdf (YouTube → PDF → B2 download link)

## ─── Backblaze B2 (cloud storage for PDF downloads) ───
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=

## ─── HuggingFace (Whisper fallback for transcription) ───
HF_TOKEN=
